# .env is OPTIONAL — all secrets are auto-generated by the init container on first boot.
#
# Only set these if you want to override the auto-generated values
# (e.g. you're rotating secrets or restoring from backup).
#
# DB_ROOT_PASSWORD=my_custom_root_pass
# DB_PASSWORD=my_custom_db_pass
# JWT_SECRET=<128 hex chars>
# MASTER_ENCRYPTION_KEY=<64 hex chars>
#
# Optional overrides for the admin one-click update flow.
# The stock compose file defaults to:
#   cd /opt/mycloud && sh ./scripts/apply-update.sh
# and rebuilds backend/frontend/nginx through the host Docker socket.
# MYCLOUD_UPDATE_COMMAND=cd /opt/mycloud && sh ./scripts/apply-update.sh
# MYCLOUD_UPDATE_LOG_PATH=/tmp/mycloud-update.log
# MYCLOUD_UPDATE_SERVICES=backend frontend nginx
